{
  "name": "sololedger",
  "productName": "SoloLedger",
  "private": true,
  "version": "0.1.0",
  "description": "SoloLedger 独账 — 为一人公司打造的智能记账与经营管理桌面应用",
  "author": "alotie418",
  "license": "UNLICENSED",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "check:locale-matrix": "node --experimental-loader ./scripts/_ts-resolver.mjs scripts/check-locale-matrix.mjs",
    "check:raw-keys": "node scripts/check-raw-key-leaks.mjs",
    "check:agent-providers": "node scripts/test-agent-providers.mjs",
    "check:metrics": "node scripts/test-metrics.mjs",
    "check:theme": "node scripts/check-theme.mjs",
    "check:providers": "node scripts/check-providers.mjs",
    "check:ocr-mapping": "node scripts/test-ocr-mapping.mjs",
    "check:provider-names": "node scripts/test-provider-names.mjs",
    "check:offline": "node scripts/check-offline.mjs",
    "check:i18n-keys": "node scripts/check-i18n-keys.mjs",
    "check:i18n-placeholders": "node scripts/check-i18n-placeholders.mjs",
    "check:disclaimer": "node scripts/check-disclaimer.mjs",
    "check:ai-tone": "node scripts/check-ai-tone.mjs",
    "check:tax-labels": "node scripts/check-tax-labels.mjs",
    "check:report-titles": "node scripts/check-report-titles.mjs",
    "check:hardcoded-rates": "node scripts/check-hardcoded-rates.mjs",
    "check:us-tax-params": "node scripts/check-us-tax-params.mjs",
    "check:cogs-split": "node scripts/test-cogs-split.mjs",
    "check:recategorize": "node scripts/test-recategorize.mjs",
    "check:report-source": "node scripts/test-report-source.mjs",
    "check:cashflow": "node scripts/test-cashflow.mjs",
    "check:auto-backup": "node scripts/test-auto-backup.mjs",
    "check:backup-bundle": "node scripts/test-backup-bundle.mjs",
    "check:csv-export": "node scripts/test-csv-export.mjs",
    "check:migrations": "node scripts/test-migrations.mjs",
    "check:handlers": "node scripts/test-handlers.mjs",
    "check:db-errors": "node scripts/test-db-errors.mjs",
    "check:system-errors": "node scripts/test-system-errors.mjs",
    "check:ai-errors": "node scripts/test-ai-errors.mjs",
    "check:no-web-fetch": "node scripts/check-no-web-fetch.mjs",
    "check:balance-classify": "node scripts/check-balance-classify.mjs",
    "check:deprec-defaults": "node scripts/check-deprec-defaults.mjs",
    "check:locale": "npm run check:locale-matrix && npm run check:raw-keys",
    "check:all": "npm run check:raw-keys && npm run check:agent-providers && npm run check:metrics && npm run check:theme && npm run check:providers && npm run check:ocr-mapping && npm run check:provider-names && npm run check:disclaimer && npm run check:ai-tone && npm run check:tax-labels && npm run check:report-titles && npm run check:hardcoded-rates && npm run check:us-tax-params && npm run check:cogs-split && npm run check:recategorize && npm run check:report-source && npm run check:cashflow && npm run check:auto-backup && npm run check:backup-bundle && npm run check:csv-export && npm run check:migrations && npm run check:handlers && npm run check:db-errors && npm run check:system-errors && npm run check:ai-errors && npm run check:no-web-fetch && npm run check:balance-classify && npm run check:deprec-defaults && npm run check:locale-matrix && npm run check:offline && npm run check:i18n-keys && npm run check:i18n-placeholders",
    "test:locale-ui": "npm run build && playwright test",
    "test:electron": "playwright test --config playwright.electron.config.ts",
    "audit:locale-ui:smoke": "node scripts/audit-locale-ui.mjs --smoke",
    "audit:locale-ui": "node scripts/audit-locale-ui.mjs --full",
    "build:dmg": "BUILD_TARGET=dmg npm run build && electron-builder --mac dmg --config electron-builder.dmg.yml",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@google/genai": "^1.40.0",
    "better-sqlite3": "^11.5.0",
    "github-markdown-css": "^5.9.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  }
}
